{
  "description": "Control your browser's tabs from command line",
  "manifest_version": 2,
  "name": "BruvTab",
  "version": "2.0.3",
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
      "128": "bruvtab-icon-128x128.png"
  },
  "permissions": ["nativeMessaging", "tabs", "activeTab", "<all_urls>"],
  "browser_specific_settings": {
    "gecko": {
      "id": "bruvtab_mediator@example.org",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "strict_min_version": "58.0"
    }
  }
}
